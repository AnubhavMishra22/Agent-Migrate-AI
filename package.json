{
  "name": "agentmigrate",
  "version": "0.1.0",
  "description": "Schema migrations for LangGraph checkpoint state in PostgreSQL",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/run.ts",
    "migrate": "tsx src/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "langgraph",
    "checkpoint",
    "migration",
    "postgresql"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
